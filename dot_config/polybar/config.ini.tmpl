; Add all machine related configurations to the .config/polybar/config-env.ini file
include-file = config-{{ .chezmoi.hostname }}.ini

[settings]
screenchange-reload = true
pseudo-transparency = true

[colors]
black = #000000
gray = #2F2F2F
darkgray = #282A2E
lightgray = #C5C8C6
white = #FFFFFF
red = #420000
orange = #BD5E02
yellow = #FFF700
lime = #A8FF00
green = #31FF00
aqua = #00FF70
lightblue = #00FFF0
blue = #000BFF
purple = #7A006C
pink = #FF00C4
; TODO remove this colors
background = ${colors.gray}
background-alt = ${colors.darkgray}
foreground = ${colors.lightgray}
primary = ${colors.yellow}
secondary = #FDFDFD
alert = #A54242
disabled = #707880

[fonts]
common-font = monospace:antialias=false:pixelsize=10;2

[bar/primary]
; Position
width = 100%
height = 20pt
radius = 6
bottom = true
; Appearence
background = ${colors.background}
foreground = ${colors.foreground}
font-0 = monospace:pixelsize=12;2
line-size = 0pt
padding-left = 0
padding-right = 1
module-margin = 1
; Monitor
monitor = ${env:MONITOR:}
monitor-strict = true
; Modules
separator = |
separator-foreground = ${colors.disabled}
modules-left = i3 xwindow
modules-center = backlight volume-all
modules-right = xkeyboard date
fixed-center = true
; Misc
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true
; Tray
tray-position = right
; Tray icon max size
tray-maxsize = 26
; WM options
wm-restack = i3
override-redirect = false

[bar/info]
; Position
width = 100%
height = 16pt
radius = 0
bottom = false
; Appearence
background = ${colors.black}
foreground = ${colors.foreground}
font-0 = ${fonts.common-font}
line-size = 0pt
padding-left = 0
padding-right = 1
module-margin = 1
; Monitor
monitor = ${env:MONITOR:}
monitor-strict = true
; Modules
separator = |
separator-foreground = ${colors.disabled}
modules-left = filesystem ytmp3usage chezmoi
modules-center = wlan eth type-c-eth
modules-right = memory cpu{{ if eq .chezmoi.hostname "dragonlady" }} gpu gpu-mem{{ end }} sys-temp sys-fan sys-power
fixed-center = true
; Misc
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true
; WM options
wm-restack = i3
override-redirect = false

[bar/secondary-info]
; Is required for autorandr postswitch to find appropriate bar
inherit = bar/info

[bar/secondary]
; Position
width = 100%
height = 20pt
radius = 6
bottom = true
; Appearence
background = ${colors.background}
foreground = ${colors.foreground}
font-0 = ${fonts.common-font}
line-size = 3pt
padding-left = 0
padding-right = 1
module-margin = 1
; Monitor
monitor = ${env:MONITOR:}
;monitor = HDMI-0
monitor-strict = true
; Modules
separator = |
separator-foreground = ${colors.disabled}
modules-left = i3 xwindow
modules-center = backlight volume-all
modules-right = xkeyboard date
fixed-center = true
; Misc
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true
; WM options
wm-restack = i3
override-redirect = false

[module/chezmoi]
type = custom/script
exec = "${HOME}/bin/polybar_chezmoi_widget.sh"
interval = 60

[module/ytmp3usage]
type = custom/script
exec = "${HOME}/bin/check_dir_usage.bash /Data/Downloads/DownloadedMusic/"
interval = 300

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
pin-workspaces = true
show-urgent = true
reverse-scroll = true

label-mode = %mode%
label-mode-foreground = ${colors.lightblue}

label-focused = %index%
label-focused-foreground = ${colors.black}
label-focused-background = ${colors.orange}
label-focused-padding = 1

label-unfocused = %index%
label-unfocused-padding = 1

label-visible = %index%
label-visible-underline = #555555
label-visible-padding = 1

label-urgent = %index%
label-urgent-foreground = ${colors.white}
label-urgent-background = ${colors.red}
label-urgent-padding = 1

[module/xwindow]
type = internal/xwindow
label = %title:0:10:...%
label-foreground = ${colors.white}

[module/filesystem]
type = internal/fs
interval = 25
; Universal mounts for all machines
mount-0 = /
mount-1 = /home
mount-2 = /Data
; Machine-specific mounts should be added to config-<hostname>.ini

label-mounted = %{F#F0C674}%mountpoint%%{F-} %percentage_used%%
label-unmounted = 

[module/memory]
type = internal/memory
interval = 2
format-prefix = "RAM "
format-prefix-foreground = ${colors.primary}
label = %percentage_used:2%%

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "CPU "
format-prefix-foreground = ${colors.primary}
label = %percentage:2%%

{{ if eq .chezmoi.hostname "dragonlady" -}}
[module/gpu]
type = custom/script
exec = nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null || echo "N/A"
interval = 2
format-prefix = "GPU "
format-prefix-foreground = ${colors.primary}
label = %output%%

[module/gpu-mem]
type = custom/script
exec = nvidia-smi --query-gpu=memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null | awk -F',' '{printf "%.0f", ($1/$2)*100}' || echo "N/A"
interval = 2
format-prefix = "VRAM "
format-prefix-foreground = ${colors.primary}
label = %output%%

{{ end -}}
[module/sys-temp]
type = custom/script
exec = "${HOME}/bin/polybar_system_stats.bash" temp
interval = 2
format-prefix = "TEMP "
format-prefix-foreground = ${colors.primary}
label = %output%

[module/sys-fan]
type = custom/script
exec = "${HOME}/bin/polybar_system_stats.bash" fan
interval = 2
format-prefix = "FAN "
format-prefix-foreground = ${colors.primary}
label = %output%

[module/sys-power]
type = custom/script
exec = "${HOME}/bin/polybar_system_stats.bash" power
interval = 2
format-prefix = "PWR "
format-prefix-foreground = ${colors.primary}
label = %output%

[network-base]
type = internal/network
interval = 5
format-connected = <label-connected>
format-disconnected = <label-disconnected>
label-disconnected = %{F#EA7D08}%ifname%%{F#707880} disconnected

[module/wlan]
inherit = network-base
interface-type = wireless
label-connected = %{F#EA7D08}%ifname%%{F-} %essid% %local_ip% 

[module/eth]
inherit = network-base
interface = eno1
label-connected = %{F#EA7D08}%ifname%%{F-} %local_ip%

[module/type-c-eth]
inherit = network-base
interface = eno2
label-connected = %{F#EA7D08}%ifname%%{F-} %local_ip%

[module/backlight]
type = internal/backlight
card = nvidia_0
use-actual-brightness = false
enable-scroll = true

label = %percentage%%
label-foreground = ${colors.white}
format = <label>
format-prefix = "Light " 
format-prefix-foreground = ${colors.primary}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

label-layout = %layout%
label-layout-foreground = ${colors.primary}

[module/volume-all]
type = custom/script
exec = "${HOME}/bin/polybar_volume_all.bash"
interval = 0.1
click-left = "${HOME}/bin/polybar_volume_all.bash left"
click-right = "${HOME}/bin/polybar_volume_all.bash right"
scroll-up = "${HOME}/bin/polybar_volume_all.bash scroll_up"
scroll-down = "${HOME}/bin/polybar_volume_all.bash scroll_down"

[module/date]
type = internal/date
interval = 1

date = %d/%b/%Y %H:%M:%S

label = %date%
label-foreground = ${colors.white}

; vim:ft=dosini
