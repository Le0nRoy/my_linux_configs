HOME_HELPER_UNIQ_SCRIPT_DIR="${HOME_HELPER_UNIQ_SCRIPT_DIR:-${HOME}/bin}"

if [[ -f "${HOME_HELPER_UNIQ_SCRIPT_DIR}/.env" ]]; then
    source "${HOME_HELPER_UNIQ_SCRIPT_DIR}/.env"
else
    source "${HOME_HELPER_UNIQ_SCRIPT_DIR}/.env.template"
fi

GDK_SCALE=1

## Apply input device settings (safe for reruns)
## This function is the single source of truth for input configuration
## Called by helper.bash functions and inputplug handler
apply_xsession_input_settings() {
    ## Disable screensaver
    xset s off
    xset s noblank
    xset -dpms

    ## Enable touchpad
    xinput list --name-only | grep -i 'Touchpad' | while read -r touchpad; do
        xinput --set-prop "${touchpad}" 'libinput Tapping Enabled' 1 2>/dev/null || true
        xinput --set-prop "${touchpad}" 'libinput Natural Scrolling Enabled' 1 2>/dev/null || true
    done
}

## Run initialization unless XSESSIONRC_SKIP_INIT is set (used by system.bash)
if [[ -z "${XSESSIONRC_SKIP_INIT}" ]]; then
    ## Enable ssh-agent (only if not already running)
    if [[ -z "${SSH_AGENT_PID}" ]] || ! kill -0 "${SSH_AGENT_PID}" 2>/dev/null; then
        eval "$(ssh-agent)"
    fi

    apply_xsession_input_settings
fi

